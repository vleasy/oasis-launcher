generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nickname  String?
  role      String   @default("user")
  language  String   @default("ru")
  avatarUrl String?
  status    String?
  bio       String?
  favoriteVersions String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameAccounts   GameAccount[]
  refreshTokens  RefreshToken[]
  sentRequests   FriendRequest[]    @relation("SentRequests")
  receivedRequests FriendRequest[]  @relation("ReceivedRequests")
  friendships    Friendship[]       @relation("UserFriendships")
  friendOf       Friendship[]       @relation("FriendOf")
  blocks         FriendBlock[]      @relation("Blocker")
  blockedBy      FriendBlock[]      @relation("Blocked")
  sentMessages   ChatMessage[]      @relation("Sender")
  receivedMessages ChatMessage[]    @relation("Recipient")
  sharedBuilds   SharedBuild[]
}

model GameAccount {
  id          String   @id @default(uuid())
  userId      String
  type        String
  username    String?
  microsoftId String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model CustomVersion {
  id               String   @id @default(uuid())
  name             String
  description      String?
  minecraftVersion String
  changelog        String?
  fileUrl          String
  fileName         String
  fileSize         Int
  sha256           String
  downloadCount    Int      @default(0)
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isPublic])
}

model FriendRequest {
  id        String   @id @default(uuid())
  senderId  String
  receiverId String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
}

model Friendship {
  id          String   @id @default(uuid())
  userId      String
  friendId    String
  createdAt   DateTime @default(now())

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model FriendBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model ChatMessage {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId])
  @@index([recipientId, read])
}

model SharedBuild {
  id           String   @id @default(uuid())
  userId       String
  code         String   @unique
  versionId    String
  mcVersion    String
  category     String
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
}
