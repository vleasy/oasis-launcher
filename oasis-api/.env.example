# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT
JWT_ACCESS_SECRET=dev-access-secret-key-32-chars-min!!change
JWT_REFRESH_SECRET=dev-refresh-secret-key-32-chars-min!change
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Database (SQLite for local dev)
DATABASE_URL=file:./dev.db

# Redis (optional — in-memory fallback used if missing)
REDIS_URL=

# CORS
CORS_ORIGIN=http://localhost:1420,http://localhost:5173,*

# Upload
UPLOAD_DIR=./uploads/versions
MAX_FILE_SIZE=2147483648

# Mojang API
MOJANG_VERSION_MANIFEST_URL=https://piston-meta.mojang.com/mc/game/version_manifest_v2.json
MOJANG_RATE_LIMIT=60

# Logging
LOG_LEVEL=info
